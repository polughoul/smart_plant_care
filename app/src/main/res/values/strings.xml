    <string name="help_title">Help</string>
    <string name="help_section_watering_title">How to mark a plant as watered</string>
    <string name="help_section_watering_body">In My Garden, swipe a plant card to the right to reveal actions. Tap the check icon to mark it as watered. You can also select multiple plants and use Watered.</string>
    <string name="help_section_edit_title">How to change name or photo</string>
    <string name="help_section_edit_body">In My Garden, swipe a plant card to the right and tap the edit icon to change name, watering interval, or photo.</string>
    <string name="help_section_history_title">How to clear watering history</string>
    <string name="help_section_history_body">Open a plant and tap View all in Watering history. On the history screen, tap the trash icon in the top bar to clear. You can undo right after.</string>
    <string name="help_section_search_title">How to add a new plant</string>
    <string name="help_section_search_body">Use Find plant to search the catalog, then add to My Garden. You can also create a custom plant.</string>
    <string name="help_section_reminders_title">How to enable reminders</string>
    <string name="help_section_reminders_body">Go to Settings and enable Watering reminders. If needed, allow notifications in system settings.</string>
